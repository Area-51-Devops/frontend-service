# ──────────────────────────────────────────────────────────────────────────────
# LEGACY / UNUSED — These variables are NOT read by the frontend code.
#
# src/api.js uses relative paths (/api/user, /api/account, etc.) so that
# Nginx (in both Docker Compose AND Kubernetes) proxies the requests.
#
# In Docker Compose → nginx proxies to Docker service hostnames
# In Kubernetes     → k8s/17-nginx-configmap.yaml is mounted over the built
#                      nginx.conf, proxying to K8s FQDN service names.
#
# These hardcoded IPs remain here only for historical reference.
# ──────────────────────────────────────────────────────────────────────────────
VITE_USER_URL=http://34.229.10.219:3001
VITE_ACCOUNT_URL=http://34.229.10.219:3004
VITE_TX_URL=http://34.229.10.219:3003
VITE_LOAN_URL=http://34.229.10.219:3005
VITE_REPORT_URL=http://34.229.10.219:3010
